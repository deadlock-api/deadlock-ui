{
  "name": "@deadlock-api/ui-core",
  "version": "1.0.1",
  "description": "Web Components library for Deadlock game items UI — built with StencilJS",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2017": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/main/main.esm.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/types/index.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    },
    "./dist/components/*": "./dist/components/*"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "dev": "stencil build --dev --watch",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil test --spec",
    "generate": "stencil generate"
  },
  "keywords": [
    "deadlock",
    "web-components",
    "stencil",
    "game",
    "items",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/deadlock-api/deadlock-ui"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.0",
    "@stencil/store": "^2.0.16"
  },
  "devDependencies": {
    "@stencil/core": "^4.22.0",
    "@stencil/react-output-target": "^1.0.0",
    "@stencil/vue-output-target": "^0.8.0",
    "typescript": "^5.7.0"
  }
}

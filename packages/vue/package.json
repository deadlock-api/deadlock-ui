{
  "name": "@deadlock-api/ui-vue",
  "version": "1.0.1",
  "description": "Vue bindings for Deadlock UI web components",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/fix-esm-imports.mjs dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/deadlock-api/deadlock-ui"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@deadlock-api/ui-core": "*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "vue": "^3.5.0",
    "typescript": "^5.7.0"
  }
}
